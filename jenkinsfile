pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/nitin-projects/SIT-223-Task8.2C---DevSecOps.git'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                // Using 'bat' because Jenkins is running on Windows
                bat 'npm install'
            }
        }
        
        stage('Run Tests') {
            steps {
                // 'exit /b 0' forces the step to succeed even if tests fail, allowing the pipeline to continue
                bat 'npm test || exit /b 0'
            }
        }
        
        stage('Generate Coverage Report') {
            steps {
                bat 'npm run coverage || exit /b 0'
            }
        }
        
        stage('NPM Audit (Security Scan)') {
            steps {
                // This step performs the security audit
                bat 'npm audit || exit /b 0'
            }
        }
    }
}
