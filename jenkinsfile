pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Make sure to replace this URL with your actual GitHub repo URL
                git branch: 'main', url: 'https://github.com/nitin-projects/SIT-223-Task8.2C---DevSecOps.git'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                // Windows users: change 'sh' to 'bat'
                sh 'npm install'
            }
        }
        
        stage('Run Tests') {
            steps {
                // The '|| true' ensures the pipeline continues even if tests fail
                // Windows users: change 'sh' to 'bat' and '|| true' to '|| exit /b 0'
                sh 'npm test || true'
            }
        }
        
        stage('Generate Coverage Report') {
            steps {
                // Windows users: change 'sh' to 'bat' and '|| true' to '|| exit /b 0'
                sh 'npm run coverage || true'
            }
        }
        
        stage('NPM Audit (Security Scan)') {
            steps {
                // This is where the vulnerabilities are found
                // Windows users: change 'sh' to 'bat' and '|| true' to '|| exit /b 0'
                sh 'npm audit || true'
            }
        }
    }
}
